---
---

<footer class="footer" id="footer">
  <div class="footer__content container">
    <div class="footer__top">
      <div class="footer__brand">
        <span class="footer__logo">WANDER<span class="footer__logo-dot">.</span></span>
        <span class="footer__tagline">Cada marca es un territorio por descubrir.</span>
      </div>

      <nav class="footer__nav" aria-label="Navegación de pie de página">
        <a href="/#trabajos">Trabajos</a>
        <a href="/#servicios">Servicios</a>
        <a href="/blog">Blog</a>
        <a href="/#contacto">Contacto</a>
      </nav>

      <div class="footer__social">
        <a href="mailto:hola@estudiowander.com">Email</a>
        <a href="https://instagram.com/estudiowander" target="_blank" rel="noopener">Instagram</a>
        <a href="https://linkedin.com/company/estudiowander" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://behance.net/estudiowander" target="_blank" rel="noopener">Behance</a>
      </div>
    </div>

    <hr class="footer__rule" />

    <div class="footer__bottom">
      <p class="footer__copy">
        &copy; {new Date().getFullYear()} Estudio Wander
      </p>
      <p class="footer__motto">El que no explora, no descubre.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--negro);
    color: var(--hueso);
    padding: var(--space-xl) 0 var(--space-md);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__logo {
    font-family: var(--font-main);
    font-weight: 700;
    font-size: var(--fs-base);
    letter-spacing: var(--tracking-wide);
  }

  .footer__logo-dot { color: var(--naranja); }

  .footer__tagline {
    font-size: var(--fs-sm);
    color: var(--gris);
    max-width: 280px;
    line-height: 1.5;
  }

  .footer__nav,
  .footer__social {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer__nav a,
  .footer__social a {
    font-size: var(--fs-sm);
    color: var(--gris);
    transition: color var(--duration-fast);
  }

  .footer__nav a:hover,
  .footer__social a:hover {
    color: var(--hueso);
  }

  .footer__rule {
    border: none;
    height: 1px;
    background: rgba(255,255,255,0.08);
    margin: var(--space-lg) 0 var(--space-sm);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer__copy {
    font-size: var(--fs-xs);
    color: var(--gris);
  }

  .footer__motto {
    font-size: var(--fs-xs);
    color: var(--gris);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .footer__bottom {
      flex-direction: column;
      gap: var(--space-xs);
      text-align: center;
    }
  }
</style>
