---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<section class="blog-preview section-padding" id="blog">
  <div class="container">
    <div class="blog-preview__header">
      <span class="label">Blog</span>
      <h2 class="blog-preview__title">Últimas notas</h2>
    </div>

    <div class="blog-preview__list">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="blog-item animate-on-scroll">
          <time class="blog-item__date label" datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('es-AR', { year: 'numeric', month: 'short', day: 'numeric' })}
          </time>
          <div class="blog-item__body">
            <h4 class="blog-item__title">{post.data.title}</h4>
            <p class="blog-item__desc">{post.data.description}</p>
          </div>
          <span class="blog-item__arrow">→</span>
        </a>
      ))}
    </div>

    <div class="blog-preview__footer">
      <a href="/blog" class="btn btn--outline">Ver todo el blog</a>
    </div>
  </div>
</section>

<style>
  .blog-preview {
    background: var(--crema);
  }

  .blog-preview__header {
    margin-bottom: var(--space-lg);
  }

  .blog-preview__header .label {
    color: var(--lila);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .blog-preview__title {
    font-size: var(--fs-xl);
    letter-spacing: var(--tracking-tight);
  }

  .blog-preview__list {
    display: flex;
    flex-direction: column;
  }

  .blog-item {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: var(--space-md);
    align-items: center;
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--borde);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .blog-item:first-child {
    border-top: 1px solid var(--borde);
  }

  .blog-item:hover {
    padding-left: var(--space-sm);
    background: var(--lila-soft);
    border-radius: var(--radius-md);
  }

  .blog-item__date {
    color: var(--gris);
    font-size: var(--fs-xs);
  }

  .blog-item__body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .blog-item__title {
    font-size: var(--fs-base);
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    line-height: 1.3;
  }

  .blog-item__desc {
    font-size: var(--fs-sm);
    color: var(--gris);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-item__arrow {
    font-size: var(--fs-md);
    color: var(--borde);
    transition: all var(--duration-fast);
  }

  .blog-item:hover .blog-item__arrow {
    color: var(--lila);
    transform: translateX(4px);
  }

  .blog-preview__footer {
    text-align: center;
    margin-top: var(--space-xl);
  }

  @media (max-width: 768px) {
    .blog-item {
      grid-template-columns: 1fr auto;
      gap: var(--space-sm);
    }

    .blog-item__date {
      grid-column: 1 / -1;
    }
  }
</style>
